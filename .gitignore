.agents/
.claude/

# generated eval reports
backend/eval/reports/

# Pioneer.ai GLiNER2 fine-tuned weights — gitignored by default,
# but the v2 + v3 LoRA adapters (~11 MB each) ship in-repo so anyone
# cloning gets the production router straight away.
pioneer/weights/*
!pioneer/weights/inazuma-gliner2-v2/
!pioneer/weights/inazuma-gliner2-ner-v3/
